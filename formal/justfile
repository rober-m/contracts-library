# Formal-verification pipeline. Run from this directory (`formal/`).
#
# Compile the Aiken validators (in ../onchain) into a CIP-57 blueprint
# (../onchain/plutus.json) and re-check the Lean (Lean-Blaster) proofs against
# that bytecode. The proofs `#import_blueprints` the compiled validator straight
# from plutus.json, so they target the *actual compiled validator*, not a
# hand-written model.
#
# Lean v4.24.0 + Z3 4.15.2 come from ./flake.nix (`nix develop`); `aiken` must
# be on PATH. Run `just deps` once before the first `just verify`.

onchain   := "../onchain"
artifacts := onchain / "artifacts"

# Full pipeline: build -> verify.
default: verify

# List recipes.
list:
    @just --list

# Fetch the Lean dependencies (Blaster). Run once, or after bumping its rev.
deps:
    nix develop --command lake update

# Compile validators into ../onchain/plutus.json (CIP-57 blueprint).
build:
    cd {{onchain}} && aiken build

# Re-check every theorem. Runs inside the flake's shell (Lean v4.24.0 + Z3
# 4.15.2). Drop `nix develop --command` if the toolchain is already on PATH.

# Re-check every Lean proof against the current blueprint (annotated lake output).
verify: build
    nix develop --command bash -c 'set -o pipefail; lake build 2>&1 | awk -f scripts/annotate-blaster-logs.awk'

clean:
    rm -rf {{artifacts}}
    nix develop --command lake clean
